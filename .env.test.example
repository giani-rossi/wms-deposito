# Copiá este archivo a `.env.test.local` (no commitear) para tests de integración.
# Requiere Supabase local: `npm run db:start` y `npm run db:reset`

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-anon-key-from-supabase-status
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-supabase-status

TEST_STAFF_EMAIL=staff-integration@test.local
TEST_STAFF_PASSWORD=integration-test-password-123
